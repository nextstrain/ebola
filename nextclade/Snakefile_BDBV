rule export:
    input:
        tree="results/{species}/tree.nwk",
        metadata="results/{species}/metadata.tsv",
        ancestral_seqs="results/{species}/muts.json",
        auspice_config="results/{species}/auspice_config.json",
        # outbreaks="results/{species}/outbreaks.json",
    output:
        auspice_tree="results/{species}/tree.json",
    shell:
        """
        augur export v2 --tree {input.tree} \
                    --metadata {input.metadata} \
                    --metadata-id-columns accession \
                    --auspice-config {input.auspice_config} \
                    --node-data {input.ancestral_seqs} \
                    --include-root-sequence-inline \
                    --output {output.auspice_tree} \
        """


rule replace_taxon_names:
    input:
        metadata="results/{species}/metadata.tsv",
        auspice_tree="results/{species}/tree.json",
    output:
        auspice_tree="auspice/tree_{species}.json",
    run:
        import json
        import pandas as pd

        with open(input.auspice_tree) as f:
            tree = json.load(f)

        metadata = pd.read_csv(input.metadata, sep="\t")
        accession_to_strain = dict(zip(metadata["accession"], metadata["strain"]))

        def replace_name(node):
            if "name" in node and node["name"] in accession_to_strain:
                node["name"] = accession_to_strain[node["name"]]
            if "children" in node:
                for child in node["children"]:
                    replace_name(child)

        replace_name(tree["tree"])

        with open(output.auspice_tree, "w") as f:
            json.dump(tree, f)


rule example_sequences:
    input:
        sequences="results/{species}/sequences.fasta",
        metadata="results/{species}/metadata.tsv",
    output:
        example_sequences="results/{species}/example_sequences.fasta",
    shell:
        """
        augur filter --metadata-id-columns accession strain --metadata {input.metadata} --sequences {input.sequences} \
                     --subsample-max-sequences 10 --min-length 500 \
                     --output-sequences {output.example_sequences}
        """


rule assemble_dataset:
    input:
        tree="auspice/tree_{species}.json",
        example_sequences="results/{species}/example_sequences.fasta",
        changelog="results/{species}/CHANGELOG.md",
    output:
        dataset_tree="datasets/{species}/tree.json",
        changelog="datasets/{species}/CHANGELOG.md",
    params:
        dataset_dir="datasets/{species}",
    shell:
        """
        cp {input.tree} {output.dataset_tree}
        cp {input.example_sequences} {params.dataset_dir}/examples.fasta
        cp ../shared/{wildcards.species}/annotation.gff {params.dataset_dir}/genome_annotation.gff3
        cp ../shared/{wildcards.species}/reference.fasta {params.dataset_dir}/reference.fasta
        cp dataset_files/{wildcards.species}/pathogen.json {params.dataset_dir}/pathogen.json
        cp {input.changelog} {params.dataset_dir}/CHANGELOG.md
        cp dataset_files/{wildcards.species}/README.md {params.dataset_dir}/README.md

        """
